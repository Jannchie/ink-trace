{
  "name": "@ink-trace/core",
  "version": "0.1.0",
  "description": "Framework-agnostic canvas ink stroke simulation.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jannchie/ink-trace.git",
    "directory": "packages/core"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "d3-color": "^3.1.0",
    "svg-path-properties": "^2.0.2"
  },
  "devDependencies": {
    "@types/d3-color": "^3.1.3",
    "vitest": "^4.1.5"
  }
}
