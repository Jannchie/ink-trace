{
  "name": "@ink-trace/react",
  "version": "0.1.0",
  "description": "React component for canvas ink stroke simulation.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jannchie/ink-trace.git",
    "directory": "packages/react"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean --external react --external @ink-trace/core",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --environment jsdom"
  },
  "dependencies": {
    "@ink-trace/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.0",
    "react-dom": "^19.2.5",
    "vitest": "^4.1.5"
  }
}
